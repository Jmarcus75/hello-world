apiVersion: networking.k8s.io/v1
kind: Ingress

metadata:
  name: hello-world-ingress
  namespace: {{ k8s_namespace }}
  labels:
    app: hello-world

spec:
  ingressClassName: nginx

  rules:
  - host: {{ ingress_host }}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: hello-world-service
            port:
              number: 8080
